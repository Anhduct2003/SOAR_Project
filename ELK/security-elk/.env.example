# Security Incident Response Dashboard - Environment Variables Template
# COPY THIS FILE TO .env AND FILL IN YOUR VALUES
# NEVER COMMIT THE .env FILE TO VERSION CONTROL

# Application
NODE_ENV=production
PORT=5000
FRONTEND_URL=http://localhost:3000

# MongoDB
MONGODB_URI=mongodb://admin:CHANGE_ME@mongodb:27017/security_incidents?authSource=admin
MONGO_INITDB_ROOT_USERNAME=admin
MONGO_INITDB_ROOT_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# JWT - Generate a strong secret: openssl rand -base64 64
JWT_SECRET=CHANGE_ME_GENERATE_STRONG_SECRET_KEY_256_BITS
JWT_EXPIRE=30d

# App Config
DEFAULT_INCIDENT_OWNER_ID=CHANGE_ME_USER_ID

# Elasticsearch
ELASTICSEARCH_URL=http://elasticsearch:9200

# Email Configuration (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM=noreply@security.local

# Slack Configuration
SLACK_WEBHOOK_URL=your-slack-webhook-url
SLACK_CHANNEL=#security-alerts

# Telegram Configuration
TELEGRAM_BOT_TOKEN=CHANGE_ME_BOT_TOKEN
TELEGRAM_CHAT_ID=CHANGE_ME_CHAT_ID

# Logging
LOG_LEVEL=info

# Security
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Webhook Security (shared secret between ElastAlert and Backend)
WEBHOOK_SECRET=CHANGE_ME_INTERNAL_WEBHOOK_SECRET

# CORS - Comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
